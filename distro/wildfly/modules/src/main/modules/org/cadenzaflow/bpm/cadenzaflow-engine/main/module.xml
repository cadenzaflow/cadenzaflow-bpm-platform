<module xmlns="urn:jboss:module:1.0" name="org.cadenzaflow.bpm.cadenzaflow-engine">
  <resources>
    <resource-root path="cadenzaflow-engine-@project.version@.jar" />
  </resources>

  <dependencies>

    <module name="java.base" />
    <module name="java.desktop" />
    <module name="java.management" />
    <module name="java.naming" />
    <module name="java.scripting" />
    <module name="java.sql" />
    <module name="jakarta.transaction.api"/>
    <module name="jakarta.enterprise.api" />
    <module name="jakarta.inject.api" />
    <module name="jakarta.ejb.api" />
    <module name="jakarta.xml.bind.api" />
    <module name="jakarta.servlet.api" />

    <module name="org.jboss.vfs" />
    <module name="org.slf4j" />

    <module name="org.mybatis.mybatis" />
    <module name="com.fasterxml.uuid.java-uuid-generator"/>
    <module name="org.joda.time" slot="2.1" />

    <module name="org.apache.groovy.groovy-all" services="import"/>
    <module name="org.graalvm.js.js-scriptengine" services="import"/>
    <module name="org.graalvm.js.js" services="import"/>
    <module name="org.graalvm.regex.regex" services="import"/>
    <module name="org.graalvm.sdk.graal-sdk" services="import"/>
    <module name="org.graalvm.truffle.truffle-api" services="import"/>

    <module name="sun.jdk" services="import"/>

    <module name="org.cadenzaflow.bpm.model.cadenzaflow-xml-model" />
    <module name="org.cadenzaflow.bpm.model.cadenzaflow-bpmn-model" />
    <module name="org.cadenzaflow.bpm.model.cadenzaflow-cmmn-model" />
    <module name="org.cadenzaflow.bpm.model.cadenzaflow-dmn-model" />

    <module name="org.cadenzaflow.commons.cadenzaflow-commons-logging" />
    <module name="org.cadenzaflow.commons.cadenzaflow-commons-utils" />
    <module name="org.cadenzaflow.commons.cadenzaflow-commons-typed-values" export="true" />
    <module name="org.cadenzaflow.template-engines.cadenzaflow-template-engines-freemarker" services="import" />
    <module name="org.cadenzaflow.spin.cadenzaflow-spin-core" services="import"/>

    <module name="org.cadenzaflow.bpm.dmn.cadenzaflow-engine-dmn" />
    <module name="org.cadenzaflow.bpm.juel.cadenzaflow-juel" services="import"/>

  </dependencies>
