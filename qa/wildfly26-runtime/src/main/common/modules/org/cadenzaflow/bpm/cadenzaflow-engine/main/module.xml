<module xmlns="urn:jboss:module:1.0" name="org.cadenzaflow.bpm.cadenzaflow-engine">
  <resources>
    <resource-root path="cadenzaflow-engine-@project.version@.jar" />
  </resources>

  <dependencies>

    <module name="javax.api" />
    <module name="javax.transaction.api"/>
    <module name="javax.enterprise.api" />
    <module name="javax.inject.api" />
    <module name="javax.ejb.api" />
    <module name="javax.xml.bind.api" />
    <module name="javax.servlet.api" />

    <module name="org.jboss.vfs" />

    <module name="org.mybatis.mybatis" />
    <module name="com.fasterxml.uuid.java-uuid-generator"/>
    <module name="org.joda.time" slot="2.1" />
    <module name="org.apache.groovy.groovy-all" services="import"/>
    <module name="org.python.jython" services="import"/>
    <module name="org.jruby.jruby-complete" services="import"/>
    <module name="org.graalvm.js.js-scriptengine" services="import"/>

    <module name="sun.jdk" services="import"/>

    <module name="org.cadenzaflow.bpm.model.cadenzaflow-xml-model" />
    <module name="org.cadenzaflow.bpm.model.cadenzaflow-bpmn-model" />
    <module name="org.cadenzaflow.bpm.model.cadenzaflow-cmmn-model" />
    <module name="org.cadenzaflow.bpm.model.cadenzaflow-dmn-model" />

    <module name="org.camunda.commons.cadenzaflow-commons-logging" />
    <module name="org.camunda.commons.cadenzaflow-commons-utils" />
    <module name="org.camunda.commons.cadenzaflow-commons-typed-values" export="true" />
    <module name="org.camunda.template-engines.cadenzaflow-template-engines-freemarker" services="import" />
    <module name="org.camunda.spin.cadenzaflow-spin-core" services="import" />

    <module name="org.cadenzaflow.bpm.dmn.cadenzaflow-engine-dmn" />
    <module name="org.cadenzaflow.bpm.juel.cadenzaflow-juel" services="import"/>

    <module name="org.slf4j" />

  </dependencies>
</module>
